{
  "name": "stl-status-chart",
  "version": "1.0.0",
  "description": "STL Status Chart",
  "main": "gather_stats.mjs",
  "scripts": {
    "format": "prettier --write .",
    "pregather": "tsc -p src_gather/tsconfig.json",
    "gather": "node built/gather_stats.mjs",
    "premake": "tsc -p src/tsconfig.json",
    "make": "esbuild src/status_chart.mts --bundle --format=esm --minify --external:chart.js --external:chartjs-adapter-luxon --outfile=built/status_chart.mjs",
    "view": "serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microsoft/STL.git#gh-pages"
  },
  "keywords": [
    "chart"
  ],
  "author": "Microsoft",
  "license": "SEE LICENSE IN LICENSE.txt",
  "bugs": {
    "url": "https://github.com/microsoft/STL/issues"
  },
  "homepage": "https://github.com/microsoft/STL/tree/gh-pages#readme",
  "dependencies": {
    "@octokit/graphql": "^9.0.3",
    "@types/cli-progress": "^3.11.6",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.0.0",
    "@types/yargs": "^17.0.35",
    "chart.js": "^4.5.1",
    "chartjs-adapter-luxon": "^1.3.1",
    "cli-progress": "^3.12.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "luxon": "^3.7.2",
    "prettier": "^3.8.4",
    "serve": "^14.2.6",
    "typescript": "^6.0.3",
    "yargs": "^18.0.0"
  }
}
